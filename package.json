{
  "name": "geopages-template",
  "version": "0.0.1",
  "description": "Template for creating geodata atlas projects with leaflet-atlas",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "validate-config": "node scripts/validate-geojson.mjs",
    "discover-dataset": "node scripts/discover-dataset.mjs",
    "generate": "python scripts/generate-config.py"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "leaflet-atlas": "^0.2.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
